# ============================================================
# PONTE LA CAMISETA KALA — Variables de Entorno
# Local: copia este archivo como .env y completa los valores.
# Vercel: cargá estas mismas variables en Project Settings → Environment Variables.
# ============================================================

# Puerto (solo dev local; Vercel lo ignora)
PORT=3000

# ──────────────────────────────────────────────────────────
# PROVEEDOR DE IA
#   "gemini"  → gemini-3-pro-image (Google AI) — DEFAULT
#   "openai"  → gpt-image-2 (OpenAI)
# ──────────────────────────────────────────────────────────
AI_PROVIDER=gemini

# ─── Google AI Studio ─────────────────────────────────────
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OpenAI (alternativa) ─────────────────────────────────
# Obtén tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Modo Demo ────────────────────────────────────────────
# true  = placeholder para probar la UI sin API key
# false = llama a la API real (requiere GEMINI_API_KEY válida)
DEMO_MODE=true
