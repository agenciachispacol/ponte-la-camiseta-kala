# ============================================================
# PONTE LA CAMISETA KALA — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# ============================================================

PORT=3000

# ──────────────────────────────────────────────────────────
# PROVEEDOR DE IA
#   "gemini"  → gemini-3-pro-image (Google AI) — DEFAULT
#   "openai"  → gpt-image-2 (OpenAI)
# ──────────────────────────────────────────────────────────
AI_PROVIDER=gemini

# ─── Google AI Studio ─────────────────────────────────────
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo: gemini-3-pro-image (análisis facial + generación)
GEMINI_MODEL=gemini-3-pro-image

# ─── OpenAI (alternativa) ─────────────────────────────────
# Obtén tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_IMAGE_MODEL=gpt-image-2

# ─── Modo Demo ────────────────────────────────────────────
# true  = placeholder para pruebas de UI sin API key
# false = llama a la API real
DEMO_MODE=true

# ─── Almacenamiento temporal ──────────────────────────────
UPLOAD_DIR=./uploads

# ─── Parámetros de generación ─────────────────────────────
IMAGE_ASPECT_RATIO=3:4
